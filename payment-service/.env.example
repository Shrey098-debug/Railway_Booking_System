PORT=4006
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://admin:your-password@localhost:5432/payment_service_database
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Redis is the event bus (Redis Streams) — payment publishes payment.success/failed here
REDIS_URL=redis://:your-password@localhost:6379

INTERNAL_SERVICE_KEY=your-internal-service-key

PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
