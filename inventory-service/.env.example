PORT=4007
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgres://admin:your-password@localhost:5432/inventory_service_database
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Redis is the event bus (Redis Streams) — inventory consumes admin.schedule-* here
REDIS_URL=redis://:your-password@localhost:6379

LOCK_TTL_SECONDS=300
LOCK_EXPIRY_INTERVAL_MS=60000

INTERNAL_SERVICE_KEY=your-internal-service-key
